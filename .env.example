# Nezora environment variables — copy to .env and fill in

# ── Required: change these before deploying ──────────────────────────────────
NEZORA_ADMIN_TOKEN=changeme-use-a-long-random-string
NEZORA_ADMIN_PASSWORD=changeme-use-a-strong-password
NEZORA_ADMIN_USERNAME=admin

# ── AI — all free options ─────────────────────────────────────────────────────
# Ollama (runs locally in Docker — completely free, no API key)
OLLAMA_MODEL=llama3.2
# OLLAMA_HOST is set automatically in docker-compose (http://ollama:11434)
# For external Ollama: OLLAMA_HOST=http://your-ollama-server:11434

# Groq (optional cloud fallback — free tier at console.groq.com)
# GROQ_API_KEY=gsk_...

# ── Ports ─────────────────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=8080

# ── Domain (auto-detected if not set) ────────────────────────────────────────
# PUBLIC_URL=https://nezora.example.com
# CORS_ALLOWED_ORIGINS=https://nezora.example.com

# ── Mobile app API endpoint (set in the Settings tab inside the app) ─────────
# The mobile app lets you configure the server URL at runtime — no env var needed
