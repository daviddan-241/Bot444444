# ── Danny's Cloud OS — Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values

# ── Required ─────────────────────────────────────────────────────────────────

# Admin authentication token (any strong random string)
ADMIN_TOKEN=change_this_to_a_strong_secret

# PostgreSQL connection string
# For docker-compose, this is set automatically.
# For external DB: postgresql://user:password@host:5432/cloudos
DATABASE_URL=postgresql://cloudos:changeme_in_production@localhost:5432/cloudos

# ── Self-hosting ──────────────────────────────────────────────────────────────

# Your public domain (used for CORS + generated app URLs)
# Leave blank to use IP address
ALLOWED_ORIGIN=https://cloud.yourdomain.com

# Docker Compose postgres password
POSTGRES_PASSWORD=changeme_in_production

# Server port (default: 8080, nginx proxies 80/443 → 8080)
PORT=8080

# Where to store project data and deployed apps
NEZORA_DATA_DIR=/data/nezora
NEZORA_APPS_DIR=/apps

# ── Optional ──────────────────────────────────────────────────────────────────

# Groq API key for AI assistant (free tier at console.groq.com)
GROQ_API_KEY=

# GitHub token for private repo deployments
# Create at: https://github.com/settings/tokens (repo scope)
GITHUB_PERSONAL_ACCESS_TOKEN=

# HuggingFace token (fallback AI, free)
HUGGINGFACE_API_KEY=
